{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.cs"],
          "src": "../Packages/com.basecity.curl-unity/Runtime"
        },
        {
          "files": ["*.cs"],
          "src": "stubs"
        }
      ],
      "dest": "api",
      "filter": "filterConfig.yml",
      "properties": {
        "DefineConstants": "UNITY_5_3_OR_NEWER"
      },
      "disableDefaultFilter": false,
      "memberLayout": "separatePages"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["toc.yml", "index.md"]
      },
      {
        "files": ["api/**.yml", "api/**/toc.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**/toc.yml"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "curl-unity",
      "_appTitle": "curl-unity",
      "_enableSearch": true,
      "_disableContribution": true,
      "pdf": false
    },
    "xref": [
      "https://learn.microsoft.com/en-us/dotnet/.xrefmap.json"
    ]
  }
}
